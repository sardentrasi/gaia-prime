# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
USERS_ALLOWED=user1_id,user2_id

# LLM CONFIGURATION
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=model_name_here
OLLAMA_BASE_URL=api_base_url_here

# EMBEDDING SETTINGS
EMBEDDING_API_KEY=your_embedding_key_here
LLM_EMBEDDING_MODEL=embedding_model_here
EMBEDDING_API_BASE=api_base_url_here
EMBEDDING_ENCODING_FORMAT=float

# TIMEZONE
TIMEZONE=Asia/Jakarta

# GMAIL ACCOUNTS
GMAIL_ACCOUNTS='[
    {
        "name": "account_name",
        "category": "personal_or_work",
        "credentials_path": "path/to/credentials.json",
        "email": "your_email@gmail.com",
        "enabled": false
    }
]'

# OUTLOOK ACCOUNTS
OUTLOOK_ACCOUNTS='[
    {
        "name": "account_name",
        "category": "work_or_personal",
        "client_id": "your_azure_client_id",
        "client_secret": "your_azure_client_secret",
        "tenant_id": "common_or_tenant_id",
        "email": "your_email@outlook.com",
        "enabled": false
    }
]'

# IMAP ACCOUNTS
IMAP_ACCOUNTS='[
    {
        "name": "account_name",
        "display_name": "display_name",
        "category": "work_or_personal",
        "host": "imap_server_host",
        "port": 993,
        "username": "your_email@domain.com",
        "password": "your_password_or_app_secret",
        "smtp_server": "smtp_server_host",
        "smtp_port": 587,
        "smtp_user": "your_email@domain.com",
        "smtp_password": "your_password_or_app_secret",
        "enabled": false
    }
]'
